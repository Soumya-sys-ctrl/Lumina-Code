{
    "name": "lumina-code-platform",
    "version": "1.0.0",
    "scripts": {
        "services:up": "docker compose up -d redis",
        "services:down": "docker compose down",
        "dev:server": "npm --prefix server run dev",
        "dev:worker": "npm --prefix worker run dev",
        "dev:client": "npm --prefix client run dev -- --open",
        "dev": "npm run services:up && concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:client\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}